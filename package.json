{
  "name": "learning-machine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lessons:export": "node scripts/export_lessons.mjs",
    "lessons:native": "node scripts/build_native_lessons.mjs",
    "lessons:clean": "node scripts/clean_lessons.mjs",
    "lessons:build": "npm run lessons:export && npm run lessons:native && npm run lessons:clean",
    "lessons:serve": "npm run lessons:build && node scripts/serve_static.mjs web/lessons/public 8080",
    "lessons:dev": "npm run lessons:serve",
    "test:reader": "node --test tests/reader-progress-api.test.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  }
}
